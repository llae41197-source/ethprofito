generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPPORT
}

enum AssetClass {
  CRYPTO
  STOCK
  METAL
  FIAT
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  FILLED
  CANCELLED
  REJECTED
}

enum LedgerEntryType {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
  TRADE
  FEE
  HOLD
  RELEASE
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String?
  name          String?
  role          UserRole      @default(USER)
  isRestricted  Boolean       @default(false)
  kycStatus     String        @default("PENDING")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  balances      Balance[]
  trades        Trade[]
  managedLogs   AuditLog[]    @relation("AuditActor")
  targetLogs    AuditLog[]    @relation("AuditTarget")
  ledgerEntries LedgerEntry[]
}

model Asset {
  id             String          @id @default(cuid())
  symbol         String          @unique
  name           String
  assetClass     AssetClass
  isTradeEnabled Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  balances       Balance[]
  trades         Trade[]
  addresses      DepositAddress[]
  ledgerEntries  LedgerEntry[]
}

model Balance {
  id           String   @id @default(cuid())
  userId       String
  assetId      String
  amount       Decimal  @default(0)
  lockedAmount Decimal  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

model Trade {
  id             String      @id @default(cuid())
  userId         String
  assetId        String
  marketSymbol   String
  side           TradeSide
  quantity       Decimal
  entryPrice     Decimal
  executionPrice Decimal?
  feeAmount      Decimal     @default(0)
  status         TradeStatus @default(OPEN)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset          Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model DepositAddress {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetCode String
  network   String
  address   String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([assetCode, network])
}

model LedgerEntry {
  id        String          @id @default(cuid())
  userId    String
  assetId   String
  type      LedgerEntryType
  amount    Decimal
  reference String?
  notes     String?
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  userId     String?
  action     String
  targetType String
  targetId   String?
  meta       String?
  createdAt  DateTime @default(now())
  admin      User?    @relation("AuditActor", fields: [adminId], references: [id], onDelete: SetNull)
  user       User?    @relation("AuditTarget", fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
}
