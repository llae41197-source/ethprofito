generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPPORT
}

enum AssetClass {
  CRYPTO
  STOCK
  METAL
  FIAT
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  FILLED
  CANCELLED
  REJECTED
}

enum LedgerEntryType {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
  TRADE
  FEE
  HOLD
  RELEASE
}

enum DepositSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BinaryOptionDirection {
  CALL
  PUT
}

enum BinaryOptionStatus {
  OPEN
  WON
  LOST
  CANCELLED
}

enum WithdrawalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SwapOrderStatus {
  PENDING
  COMPLETED
  REJECTED
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  walletAddress String?
  passwordHash  String?
  name          String?
  role          UserRole      @default(USER)
  isRestricted  Boolean       @default(false)
  kycStatus     String        @default("PENDING")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  balances      Balance[]
  trades        Trade[]
  binaryOptions BinaryOptionTrade[]
  depositSubmissions DepositSubmission[]
  withdrawalRequests WithdrawalRequest[]
  swapOrders        SwapOrder[]
  managedLogs   AuditLog[]    @relation("AuditActor")
  targetLogs    AuditLog[]    @relation("AuditTarget")
  ledgerEntries LedgerEntry[]

  @@index([walletAddress])
}

model Asset {
  id             String          @id @default(cuid())
  symbol         String          @unique
  name           String
  assetClass     AssetClass
  isTradeEnabled Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  balances       Balance[]
  trades         Trade[]
  binaryOptions  BinaryOptionTrade[]
  depositSubmissions DepositSubmission[]
  withdrawalRequests WithdrawalRequest[] @relation("WithdrawalAsset")
  swapFromOrders     SwapOrder[]         @relation("SwapFromAsset")
  swapToOrders       SwapOrder[]         @relation("SwapToAsset")
  addresses      DepositAddress[]
  ledgerEntries  LedgerEntry[]
}

model Balance {
  id           String   @id @default(cuid())
  userId       String
  assetId      String
  amount       Decimal  @default(0)
  lockedAmount Decimal  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

model Trade {
  id             String      @id @default(cuid())
  userId         String
  assetId        String
  marketSymbol   String
  side           TradeSide
  quantity       Decimal
  entryPrice     Decimal
  executionPrice Decimal?
  feeAmount      Decimal     @default(0)
  status         TradeStatus @default(OPEN)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset          Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model DepositAddress {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetCode String
  network   String
  address   String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([assetCode, network])
}

model LedgerEntry {
  id        String          @id @default(cuid())
  userId    String
  assetId   String
  type      LedgerEntryType
  amount    Decimal
  reference String?
  notes     String?
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  userId     String?
  action     String
  targetType String
  targetId   String?
  meta       String?
  createdAt  DateTime @default(now())
  admin      User?    @relation("AuditActor", fields: [adminId], references: [id], onDelete: SetNull)
  user       User?    @relation("AuditTarget", fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
}

model DepositSubmission {
  id              String                  @id @default(cuid())
  userId          String
  assetId         String
  network         String
  txHash          String?
  amount          Decimal
  screenshotName  String?
  screenshotData  String?
  note            String?
  adminNote       String?
  status          DepositSubmissionStatus @default(PENDING)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  reviewedAt      DateTime?
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset           Asset                   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model BinaryOptionTrade {
  id             String                @id @default(cuid())
  userId         String
  assetId        String
  marketSymbol   String
  direction      BinaryOptionDirection
  durationSeconds Int
  payoutPercent  Int
  stakeAmount    Decimal
  openingPrice   Decimal
  closingPrice   Decimal?
  payoutAmount   Decimal?
  status         BinaryOptionStatus    @default(OPEN)
  expiresAt      DateTime
  settledAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset          Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model WithdrawalRequest {
  id             String                  @id @default(cuid())
  userId         String
  assetId        String
  amount         Decimal
  destination    String
  network        String
  note           String?
  adminNote      String?
  status         WithdrawalRequestStatus @default(PENDING)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  reviewedAt     DateTime?
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset          Asset                   @relation("WithdrawalAsset", fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model SwapOrder {
  id             String          @id @default(cuid())
  userId         String
  fromAssetId    String
  toAssetId      String
  fromAmount     Decimal
  toAmount       Decimal
  rate           Decimal
  status         SwapOrderStatus @default(COMPLETED)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  note           String?
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAsset      Asset           @relation("SwapFromAsset", fields: [fromAssetId], references: [id], onDelete: Cascade)
  toAsset        Asset           @relation("SwapToAsset", fields: [toAssetId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
